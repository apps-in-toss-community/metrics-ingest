{
  "name": "metrics-ingest",
  "version": "0.0.0",
  "description": "Anonymous, opt-in usage telemetry endpoint for apps-in-toss-community dev tools",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply aitc-metrics-staging --local",
    "db:migrate:staging": "wrangler d1 migrations apply aitc-metrics-staging --remote --env staging",
    "db:migrate:production": "wrangler d1 migrations apply aitc-metrics --remote --env production"
  },
  "dependencies": {
    "hono": "^4.6.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@types/node": "^25.6.2",
    "miniflare": "^4.20260507.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.90.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "telemetry",
    "metrics",
    "apps-in-toss",
    "community"
  ],
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd"
    ]
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/apps-in-toss-community/metrics-ingest"
  },
  "bugs": {
    "url": "https://github.com/apps-in-toss-community/metrics-ingest/issues"
  }
}
